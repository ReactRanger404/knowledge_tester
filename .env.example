# LLM 配置（所有 Agent 公用）
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash

# 各 Agent 可独立指定模型（不配置则复用 LLM_MODEL）
# LLM_MODEL_KP=deepseek-v4-flash   # 知识提取
# LLM_MODEL_QG=gpt-4o              # 出题
# LLM_MODEL_TA=...                  # 题型适配
# LLM_MODEL_QR=...                  # 质量审核
# LLM_MODEL_GR=...                  # 判题
# LLM_MODEL_EA=...                  # 错题分析

# Vision 图表描述（OCR 专用，推荐智谱 GLM-4V-Flash 免费版）
# VISION_API_KEY=your-zhipu-api-key
# VISION_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# VISION_MODEL=glm-4v-flash
